rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /players/{playerId} {
      function isValidPlayer(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.name is string && data.name.size() <= 50 &&
               data.level is int && data.level >= 1 &&
               data.bounty is number && data.bounty >= 0 &&
               data.region is string &&
               (data.motto == null || (data.motto is string && data.motto.size() <= 100)) &&
               (data.avatar == null || data.avatar is string) &&
               data.fruits is list &&
               data.achievements is list &&
               data.keys().hasAll(['id', 'name', 'level', 'bounty', 'region']) &&
               data.keys().size() <= 16;
      }

      allow list: if true;
      allow get: if true;

      allow create: if isSignedIn() && 
                      isValidId(playerId) && 
                      request.auth.uid == playerId &&
                      isValidPlayer(request.resource.data) &&
                      request.resource.data.id == request.auth.uid;

      allow update: if isOwner(playerId) &&
                      isValidPlayer(request.resource.data) &&
                      request.resource.data.id == existing().id &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        'name', 'motto', 'avatar', 'level', 'bounty', 'fruits', 'achievements', 'socials', 'updatedAt'
                      ]);
      
      allow delete: if isOwner(playerId);
    }

    match /crews/{crewId} {
      function isValidCrew(data) {
        return data.id is string && data.id.size() <= 128 &&
               data.name is string && data.name.size() <= 30 &&
               data.tag is string && data.tag.size() <= 5 &&
               data.leaderId is string &&
               data.bounty is number &&
               data.members is list &&
               data.keys().hasAll(['id', 'name', 'leaderId', 'bounty', 'members']) &&
               data.keys().size() <= 15;
      }

      allow list: if true;
      allow get: if true;

      allow create: if isSignedIn() && 
                      isValidId(crewId) && 
                      isValidCrew(request.resource.data) &&
                      request.resource.data.leaderId == request.auth.uid;

      allow update: if isSignedIn() && (
                      (request.auth.uid == resource.data.leaderId && isValidCrew(request.resource.data)) ||
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberCount', 'bounty']))
                    );

      allow delete: if isSignedIn() && request.auth.uid == resource.data.leaderId;
    }
  }
}
